# Frontend env. ONLY public-safe values belong here.
# Vite exposes any VITE_-prefixed var to the browser bundle.
# Never put a Helius key, service_role key, or any secret in this file.
# Server-only secrets live in the Supabase project env, not here.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional. Solana RPC the browser connects through.
# Unset = the rpc-proxy Supabase edge function (holds the Helius key
# server-side, safe to leave as the default). The public mainnet-beta RPC
# blocks sendTransaction from browser origins it doesn't recognize, so it
# can't run a real dApp — don't point this there.
# VITE_RPC_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/rpc-proxy
